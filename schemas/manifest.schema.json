{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coderisktools.org/schemas/manifest.schema.json",
  "title": "Observatory Report Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "target_sha", "artifacts"],
  "properties": {
    "manifest_version": {"type": "string", "minLength": 1},
    "target_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "artifacts": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["name", "size", "sha256"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "size": {"type": "integer", "minimum": 0},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    }
  }
}
