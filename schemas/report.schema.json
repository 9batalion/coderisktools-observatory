{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coderisktools.org/schemas/report.schema.json",
  "title": "Observatory Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "repository_name", "repository_url", "target", "scan", "findings", "publication_decision", "limitations", "disclaimer"],
  "properties": {
    "schema_version": {"const": "1"},
    "repository_name": {"type": "string", "minLength": 1},
    "repository_url": {"type": "string", "pattern": "^https://github\\.com/[^/]+/[^/]+/?$"},
    "target": {
      "type": "object", "additionalProperties": false,
      "required": ["target_id", "repository_url", "requested_ref", "resolved_sha", "source", "selection_reason", "license_status", "execution_allowed", "publication_mode", "status"],
      "properties": {
        "target_id": {"type": "string", "minLength": 1},
        "repository_url": {"type": "string", "pattern": "^https://github\\.com/[^/]+/[^/]+/?$"},
        "requested_ref": {"type": "string", "minLength": 1},
        "resolved_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "source": {"type": "string", "minLength": 1},
        "selection_reason": {"type": "string", "minLength": 1},
        "license_status": {"enum": ["recognized", "unknown", "restricted"]},
        "execution_allowed": {"const": false},
        "publication_mode": {"enum": ["public-summary", "maintainer-only", "embargoed", "redacted"]},
        "status": {"enum": ["candidate", "triaged", "ready", "acquired", "scanned", "rejected"]}
      }
    },
    "scan": {
      "type": "object", "additionalProperties": false,
      "required": ["scanner_id", "scanner_version", "ruleset_digest", "target_sha", "status", "errors", "warnings"],
      "properties": {
        "scanner_id": {"type": "string", "minLength": 1},
        "scanner_version": {"type": "string", "minLength": 1},
        "ruleset_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "target_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "status": {"enum": ["complete", "partial", "failed"]},
        "errors": {"type": "array", "items": {"type": "string"}},
        "warnings": {"type": "array", "items": {"type": "string"}},
        "findings": {"type": "array"}
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["finding_id", "rule_id", "category", "severity", "confidence", "visibility", "evidence_refs", "location", "summary", "remediation", "source_scanners"],
        "properties": {
          "finding_id": {"type": "string", "minLength": 1},
          "rule_id": {"type": "string", "minLength": 1},
          "category": {"type": "string", "minLength": 1},
          "severity": {"enum": ["low", "medium", "high", "critical", "informational"]},
          "confidence": {"enum": ["low", "medium", "high", "confirmed"]},
          "visibility": {"enum": ["PUBLIC_SUMMARY", "MAINTAINER_ONLY", "EMBARGOED", "REDACTED", "REJECTED"]},
          "evidence_refs": {"type": "array", "items": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}},
          "location": {"type": "object"},
          "summary": {"type": "string", "minLength": 1},
          "remediation": {"type": "string", "minLength": 1},
          "source_scanners": {"type": "array"}
        }
      }
    },
    "publication_decision": {
      "type": "object", "additionalProperties": false,
      "required": ["decision", "reviewer", "reason_codes", "approved_artifacts", "full_findings_public"],
      "properties": {
        "decision": {"enum": ["PUBLISH", "HOLD", "REDACT", "REJECT"]},
        "reviewer": {"type": "string", "minLength": 1},
        "reason_codes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "approved_artifacts": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "full_findings_public": {"type": "boolean"},
        "override": {"type": "boolean"},
        "override_reason": {"type": ["string", "null"], "minLength": 1}
      }
    },
    "limitations": {"type": "array", "items": {"type": "string"}},
    "disclaimer": {"type": "string", "minLength": 1}
  }
}
